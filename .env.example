# ── Meta ──────────────────────────────────────────────────────────────────
# Your Facebook Page Access Token (long-lived, never-expiring preferred)
# Get it from: Meta Business Suite → Settings → Page Access Token
META_PAGE_ACCESS_TOKEN=your_page_access_token_here

# Any random string you choose — you'll paste this into the Meta webhook settings
VERIFY_TOKEN=my_secret_verify_token_123

# ── Twilio ─────────────────────────────────────────────────────────────────
# Find these at console.twilio.com → Account Info panel
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here

# The Twilio phone number assigned to you (with country code)
TWILIO_PHONE_NUMBER=+15551234567

# Your personal phone number to receive the texts (with country code)
MY_PHONE_NUMBER=+15714976688
