# ── Meta ──────────────────────────────────────────────────────────────────
# Your Facebook Page Access Token (long-lived, never-expiring preferred)
# Get it from: Meta Business Suite → Settings → Page Access Token
META_PAGE_ACCESS_TOKEN=your_page_access_token_here

# Any random string you choose — you'll paste this into the Meta webhook settings
VERIFY_TOKEN=my_secret_verify_token_123

# ── Gmail (used to fire the SMS via your carrier's email gateway) ──────────
GMAIL_ADDRESS=you@gmail.com

# Google App Password (NOT your regular Gmail password)
# Create one at: myaccount.google.com → Security → 2-Step Verification → App Passwords
# Choose "Mail" + "Other (custom name)" → generates a 16-char code like: abcd efgh ijkl mnop
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# ── SMS Gateway ────────────────────────────────────────────────────────────
# Replace 5551234567 with YOUR actual 10-digit phone number (no dashes/spaces)
#
# Carrier gateways:
#   Verizon:   5551234567@vtext.com
#   AT&T:      5551234567@txt.att.net
#   T-Mobile:  5551234567@tmomail.net
#   Cricket:   5551234567@sms.cricketwireless.net
#   Boost:     5551234567@sms.myboostmobile.com
#   Metro PCS: 5551234567@mymetropcs.com
#   US Cell:   5551234567@email.uscc.net
CARRIER_GATEWAY_EMAIL=5714976688@msg.fi.google.com
